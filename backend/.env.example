# Database — matches docker-compose.yml defaults
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/selfheal

# Google Gemini — get your free key from https://aistudio.google.com
GEMINI_API_KEY=your-key-from-aistudio.google.com
# Current recommended models: gemini-2.5-flash (stable) or gemini-3.5-flash (latest)
GEMINI_MODEL_NAME=gemini-2.5-flash

# Terraform — full path to the terraform binary on your machine
# Windows example: C:\Program Files\Terraform\terraform.exe
# macOS/Linux example: /usr/local/bin/terraform
TERRAFORM_BINARY_PATH=terraform
# Persistent cache dir so terraform init doesn't re-download providers every run
TERRAFORM_PLUGIN_CACHE_DIR=.terraform-plugin-cache

# Application
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:3000
